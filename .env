# Example environment configuration for ERP Express backend

# Port where the Express server will listen
PORT=5002

# MongoDB connection string
# For local development this might look like:
# mongodb://localhost:27017/erp_db
# MONGO_URI=mongodb+srv://mqzliyon_db_user:Liyon143@cluster0.tx9tait.mongodb.net/erp
MONGO_URI=mongodb://localhost:27017/erp_db

# Secret key used for signing JWT tokens
# Use a strong, random value in production and never commit the real value.
JWT_SECRET=super-secure-random-secret

# Optional environment name (development | production | test)
NODE_ENV=development

# Allowed frontend origins (comma-separated)
FRONTEND_URLS=https://fashiondazzling-erp.vercel.app

